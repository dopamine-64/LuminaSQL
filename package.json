{
  "name": "ai-db-assistant",
  "productName": "LuminaSQL",
  "version": "1.0.0",
  "description": "LuminaSQL Desktop App",
  "main": "electron/main.js",
  "author": "Your Name",
  "license": "ISC",
  "type": "commonjs",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win --publish=never"
  },

  "build": {
    "appId": "com.luminasql.desktop",
    "productName": "LuminaSQL",
    "publish": null,

    "directories": {
      "output": "dist"
    },

    "files": [
      "electron/**/*",
      "frontend/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist"
      }
    ],

    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.developer-tools",
      "icon": "frontend/assets/icon.icns"
    },

    "win": {
      "target": ["nsis"],
      "icon": "frontend/assets/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },

  "dependencies": {},

  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1"
  }
}